# Copy to .env.development and pass via --dart-define-from-file=.env.development
API_BASE_URL=http://localhost:3000/v1

# Google Sign-In:
#   • GOOGLE_CLIENT_ID_WEB — Web-type OAuth client ID. Used as
#     `serverClientId` on BOTH Android and iOS so the backend's
#     GOOGLE_CLIENT_ID (also the Web client ID) can verify the idToken's
#     `aud`. Required.
#   • GOOGLE_CLIENT_ID_IOS — iOS-type OAuth client ID. Required on iOS;
#     the reversed value also has to be in ios/Runner/Info.plist as a
#     CFBundleURLScheme.
#   • GOOGLE_CLIENT_ID_ANDROID — kept for documentation only. The plugin
#     does NOT take this value; Android matches the app via package name
#     + SHA-1 fingerprint registered against the Android OAuth client in
#     Google Cloud.
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
USE_REFRESH_TOKEN=false
LOG_HTTP=true
